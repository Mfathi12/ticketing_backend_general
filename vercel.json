{
    "version": 2,
    "builds": [
      {
        "src": "index.js",
        "use": "@vercel/node"
      }
    ],
    "functions": {
      "index.js": {
        "includeFiles": "node_modules/{pg,pg-pool,pg-protocol,pg-types,pg-hstore,pg-connection-string,pgpass,split2,postgres-array,postgres-bytea,postgres-date,postgres-interval,xtend}/**"
      }
    },
    "routes": [
      {
        "src": "/(.*)",
        "dest": "/index.js"
      }
    ]
  }
  